{
  "$meta": {
    "product": "sheaf",
    "tagline": "PDF Viewer + Editor",
    "version": "1.0"
  },
  "brand": {
    "gradient": {
      "type": "linear",
      "angle": 120,
      "stops": [
        "#13B8A6",
        "#3B82F6"
      ],
      "note": "top-left teal to bottom-right blue"
    },
    "teal": {
      "light": "#13B8A6",
      "dark": "#5EEAD4"
    },
    "aqua": {
      "light": "#1CA6C9",
      "dark": "#5CC7E0"
    },
    "blue": {
      "light": "#3B82F6",
      "dark": "#60A5FA"
    },
    "blueDeep": {
      "light": "#2563EB",
      "dark": "#3B82F6"
    },
    "pageTint": "#A7E8E0",
    "foldTint": "#D8F3EE"
  },
  "neutral": {
    "light": {
      "ink": "#0F172A",
      "slate700": "#334155",
      "slate500": "#64748B",
      "slate300": "#CBD5E1",
      "slate100": "#F1F5F9",
      "canvas": "#F8FAFC",
      "surface": "#FFFFFF"
    },
    "dark": {
      "bg": "#0B1220",
      "surface": "#111A2E",
      "line": "#1E293B",
      "text": "#E2E8F0",
      "muted": "#94A3B8",
      "glyph": "#CBD5E1"
    }
  },
  "icon": {
    "artboard": 24,
    "liveArea": 20,
    "padding": 2,
    "strokeWidth": 2,
    "linecap": "round",
    "linejoin": "round",
    "cornerRadius": 2,
    "sourceColor": "#1E293B",
    "note": "single flat colour; app alpha-tints per theme. Solid fill only on redaction blocks."
  },
  "type": {
    "wordmark": {
      "family": "Quicksand",
      "weight": 600,
      "case": "lowercase",
      "license": "SIL OFL 1.1"
    },
    "ui": {
      "family": "Nunito Sans",
      "license": "SIL OFL 1.1"
    }
  }
}
